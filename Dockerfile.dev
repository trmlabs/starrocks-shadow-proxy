# Dockerfile.dev — Dev-only image that consumes a pre-built binary.
#
# Skips the multi-stage build that would otherwise run `go mod download`
# inside docker (which fails behind TLS-intercepting corporate proxies like
# Zscaler where the buildkit instance doesn't inherit the host's CA bundle).
#
# Usage:
#   GOOS=linux GOARCH=amd64 CGO_ENABLED=0 go build -o starrocks-shadow-proxy-linux-amd64 .
#   docker build -t ghcr.io/trmlabs/starrocks-shadow-proxy:dev-<tag> -f Dockerfile.dev .
#   docker push    ghcr.io/trmlabs/starrocks-shadow-proxy:dev-<tag>
#
# DO NOT use this for releases — `Dockerfile` is the source of truth and is
# what GitHub Actions Release builds. This file exists solely to unblock
# local iteration during the TLS-termination work.

FROM alpine:3.21

LABEL org.opencontainers.image.source="https://github.com/trmlabs/starrocks-shadow-proxy"
LABEL org.opencontainers.image.description="StarRocks shadow traffic proxy (DEV BUILD — not for production)"
LABEL org.opencontainers.image.license="Apache-2.0"

RUN apk --no-cache add ca-certificates

WORKDIR /app
COPY starrocks-shadow-proxy-linux-amd64 ./starrocks-shadow-proxy

RUN adduser -D -u 1000 appuser
USER appuser

EXPOSE 5432 3306 9090

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:9090/health || exit 1

ENTRYPOINT ["./starrocks-shadow-proxy"]
