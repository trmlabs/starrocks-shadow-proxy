# Dev image — consumes a pre-built binary. Use the main Dockerfile for releases.
FROM alpine:3.21

LABEL org.opencontainers.image.source="https://github.com/trmlabs/starrocks-shadow-proxy"
LABEL org.opencontainers.image.description="StarRocks shadow traffic proxy (DEV BUILD — not for production)"
LABEL org.opencontainers.image.license="Apache-2.0"

RUN apk --no-cache add ca-certificates

WORKDIR /app
COPY starrocks-shadow-proxy-linux-amd64 ./starrocks-shadow-proxy

RUN adduser -D -u 1000 appuser
USER appuser

EXPOSE 5432 3306 9090

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:9090/health || exit 1

ENTRYPOINT ["./starrocks-shadow-proxy"]
